<UserControl
    d:DataContext="{d:DesignInstance Type=viewModels:JacketTabViewModel}"
    d:DesignHeight="300"
    d:DesignWidth="300"
    mc:Ignorable="d"
    x:Class="PinguTools.Pages.JacketTab"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PinguTools.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
    xmlns:viewModels="clr-namespace:PinguTools.ViewModels"
    xmlns:localization="clr-namespace:PinguTools.Localization">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <local:FilePicker
                Filter="{x:Static localization:FileFilterStrings.Image}"
                Label="{x:Static localization:Strings.Label_Input}"
                Path="{Binding JacketPath}"
                Required="True" />

            <GroupBox Header="{x:Static localization:Strings.Label_Jacket_ID}" Margin="0,4,0,0">
                <StackPanel Orientation="Horizontal">
                    <xctk:IntegerUpDown Minimum="0" Value="{Binding JacketId, Mode=TwoWay}" />
                    <TextBlock
                        Margin="2,0,0,0"
                        Text="{Binding OutputFileName}"
                        VerticalAlignment="Center" />
                </StackPanel>
            </GroupBox>

            <GroupBox Header="{x:Static localization:Strings.Label_Parameters}" Margin="0,4,0,0">
                <StackPanel>
                    <TextBlock>Size: 300x300</TextBlock>
                    <TextBlock>DXGI Format: BC1_UNORM</TextBlock>
                </StackPanel>
            </GroupBox>
        </StackPanel>

        <StackPanel Grid.Row="1" Style="{StaticResource ActionPanelStyle}">
            <Button
                Command="{Binding ActionCommand}"
                Content="{x:Static localization:Strings.Button_Convert}"
                Style="{StaticResource ActionButton}" />
        </StackPanel>

    </Grid>
</UserControl>