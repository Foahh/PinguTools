<UserControl
    d:DataContext="{d:DesignInstance Type=viewModels:MusicTabViewModel}"
    d:DesignHeight="300"
    d:DesignWidth="300"
    mc:Ignorable="d"
    x:Class="PinguTools.Pages.MusicTab"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PinguTools.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="clr-namespace:PinguTools.ViewModels"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:behaviors="clr-namespace:PinguTools.Behaviors"
    xmlns:localization="clr-namespace:PinguTools.Localization">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <local:FilePicker
                Filter="{x:Static localization:FileFilterStrings.Sound}"
                Label="{x:Static localization:Strings.Label_Input}"
                Path="{Binding MusicPath}"
                Required="True" />

            <GroupBox Header="{x:Static localization:Strings.Label_Information}" Margin="0,4,0,0">
                <Grid>
                    <local:MetaPropertyGrid SelectedObject="{Binding Model}">
                        <b:Interaction.Behaviors>
                            <behaviors:HideIfNullValueBehavior Value="{Binding Model}" />
                        </b:Interaction.Behaviors>
                    </local:MetaPropertyGrid>
                    <TextBlock
                        FontStyle="Italic"
                        HorizontalAlignment="Center"
                        Text="{x:Static localization:Strings.Label_Not_Available}"
                        VerticalAlignment="Center">
                        <b:Interaction.Behaviors>
                            <behaviors:HideIfNullValueBehavior Value="{Binding Model}" Invert="True" />
                        </b:Interaction.Behaviors>
                    </TextBlock>

                </Grid>
            </GroupBox>

            <GroupBox Header="{x:Static localization:Strings.Label_Parameters}" Margin="0,4,0,0">
                <StackPanel>
                    <TextBlock>Format: 16bit PCM, 48000Hz, 2 Channels</TextBlock>
                    <TextBlock Text="{Binding Normalizer.TargetLufs, StringFormat=TargetI: {0} LUFS}" />
                    <TextBlock Text="{Binding Normalizer.Tolerance, StringFormat=TargetLRA: {0} LU}" />
                    <TextBlock Text="{Binding Normalizer.MaxTruePeakDbTp, StringFormat=TargetTP: {0} dBFS}" />
                    <TextBlock Text="{Binding Normalizer.TruePeakLimiting, StringFormat=True Peak Limiting: {0}}" />
                    <TextBlock Text="{Binding Normalizer.LookAheadMs, StringFormat=Look-Ahead Time: {0} ms}" />
                    <TextBlock Text="{Binding Normalizer.ReleaseMs, StringFormat=Release Time: {0} ms}" />
                </StackPanel>
            </GroupBox>
        </StackPanel>

        <StackPanel Grid.Row="1" Style="{StaticResource ActionPanelStyle}">
            <Button
                Command="{Binding ActionCommand}"
                Content="{x:Static localization:Strings.Button_Convert}"
                Style="{StaticResource ActionButton}" />
        </StackPanel>

        <TextBlock
            Grid.Row="0"
            Grid.RowSpan="2"
            Style="{StaticResource FloatText}"
            Text="@Margrithm" />
    </Grid>
</UserControl>